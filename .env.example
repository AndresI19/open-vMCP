# vMCP Gateway configuration
PORT=8001
NODE_ENV=development

# Postgres (docker-compose maps container 5432 -> host 5433 to avoid host collisions)
DATABASE_URL=postgres://vmcp:vmcp@localhost:5433/vmcp

# Directory holding auth.json + servers.seed.json
CONFIG_DIR=./config

# Mask secret/PII-shaped values in tool-call arguments before persisting
REDACT_ARGS=true
