{
  "scheme": "bearer",
  "verify": true,
  "jwksUri": "http://platform-auth:8002/.well-known/jwks.json",
  "issuer": "https://api-andres.project-platform.me/auth",
  "audience": "platform",
  "claimMappings": [
    { "from": "sub", "to": "userId" },
    { "from": "username", "to": "displayName" }
  ],
  "onMissing": "reject"
}
